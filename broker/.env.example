REPLICA_DB_HOST=192.168.68.101
DB_PORT=1434
DB_NAME=snow
CDC_USER=debezium
CDC_PASSWORD=CdcPassword123!

KAFKA_TOPIC_PREFIX=snow
KAFKA_BOOTSTRAP_SERVERS=kafka-1:29092,kafka-2:29092,kafka-3:29092
KAFKA_CONNECT_URL=http://localhost:8083/connectors

CDC_TABLE_LIST=dbo.model_positions

# Snapshot Modes:
#   initial       — snapshot existing data + stream new changes
#   schema_only   — schema only, stream changes from now (no historical data)
#   initial_only  — snapshot only, no streaming after
#   when_needed   — snapshot if no offsets or prior offset unavailable
#   recovery      — re-snapshot to recover corrupted schema history
SNAPSHOT_MODE=initial